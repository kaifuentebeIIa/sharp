local settings = {
    silentAim = false,
    espEnabled = false,
    removeTraps = false,
    fov = 200 
}

local function CleanTrap(trap)
    if trap.Name == "BearTrap" or trap.Name == "CurseCircle" then
        local hitDetect = trap:FindFirstChild("HitDetect")
        if hitDetect and hitDetect:IsA("BasePart") then
            hitDetect:Destroy()
        end
    end
end

local function MonitorEntitiesFolder(folder)
    folder.ChildAdded:Connect(function(child)
        if settings.removeTraps then
            CleanTrap(child)
        end
    end)
    for _, child in ipairs(folder:GetChildren()) do
        if settings.removeTraps then
            CleanTrap(child)
        end
    end
end

for _, obj in ipairs(workspace:GetChildren()) do
    if obj.Name == "Entities" and obj:IsA("Folder") then
        MonitorEntitiesFolder(obj)
    end
end

workspace.ChildAdded:Connect(function(obj)
    if obj.Name == "Entities" and obj:IsA("Folder") then
        MonitorEntitiesFolder(obj)
    end
end)

local function IsVisible(targetHead)
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return false end
    
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {character, workspace:FindFirstChild("Characters")}
    
    local origin = character.HumanoidRootPart.Position
    local direction = targetHead.Position - origin
    
    local result = workspace:Raycast(origin, direction, rayParams)
    return not result or result.Instance:IsDescendantOf(targetHead.Parent)
end

local function GetTarget()
    local closest = nil
    local closestDist = settings.fov
    local viewport = Camera.ViewportSize
    local screenCenter = Vector2.new(viewport.X / 2, viewport.Y / 2)
    
    local charactersFolder = workspace:FindFirstChild("Characters")
    if not charactersFolder then return nil end

    for _, char in ipairs(charactersFolder:GetChildren()) do
        if char == LocalPlayer.Character then continue end
        if not char:FindFirstChild("EnemyHighlight") then continue end
        
        local head = char:FindFirstChild("Head")
        local humanoid = char:FindFirstChild("Humanoid")
        
        if head and humanoid and humanoid.Health > 0 then
            local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
            if onScreen then
                local dist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                if dist < closestDist and IsVisible(head) then
                    closestDist = dist
                    closest = head
                end
            end
        end
    end
    return closest
end

local function UpdateESP()
    local charactersFolder = workspace:FindFirstChild("Characters")
    if not charactersFolder then return end

    for _, char in ipairs(charactersFolder:GetChildren()) do
        if char:IsA("Model") and char ~= LocalPlayer.Character then
            local hasEnemy = char:FindFirstChild("EnemyHighlight")
            local existingHighlight = char:FindFirstChild("SHARP_ESP")

            if settings.espEnabled and hasEnemy then
                if not existingHighlight then
                    local h = Instance.new("Highlight")
                    h.Name = "SHARP_ESP"
                    h.FillTransparency = 1 
                    h.OutlineColor = Color3.fromRGB(255, 0, 0)
                    h.Parent = char
                end
            else
                if existingHighlight then existingHighlight:Destroy() end
            end
        end
    end
end

if m_CombatClient then
    m_CombatClient.OnLocalEvent:Connect(function(combatEvent)
        if not settings.silentAim then return end
        local target = GetTarget()
        if target then
            combatEvent.GameAction.Direction = (target.Position - combatEvent.GameAction.Position).Unit
        end
    end)
end

task.spawn(function()
    while true do
        task.wait(0.5)
        UpdateESP()
    end
end)

task.spawn(function()
